{
  "name": "@better-bull-board/client",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "type-check": "tsc --noEmit",
    "debug": "npx -y dotenv-cli -e .env -- tsx debug/index.ts",
    "prepublishOnly": "npm run build"
  },
  "license": "ISC",
  "dependencies": {
    "@rharkor/logger": "^1.3.3",
    "@t3-oss/env-core": "^0.13.11",
    "bullmq": "^5.76.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "zod": "^4.3.6"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs"
    }
  },
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0"
  }
}
