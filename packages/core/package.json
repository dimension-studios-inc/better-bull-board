{
  "name": "@better-bull-board/core",
  "main": "dist/index.mjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "type-check": "tsc --noEmit"
  },
  "license": "ISC",
  "dependencies": {
    "@better-bull-board/db": "*",
    "@better-bull-board/typescript-config": "*",
    "drizzle-orm": "*",
