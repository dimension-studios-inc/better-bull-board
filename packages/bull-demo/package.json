{
  "name": "@better-bull-board/bull-demo",
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "debug": "npx -y dotenv-cli -e .env -- tsx debug/index.ts",
    "stress:job-stream": "npx -y dotenv-cli -e .env -- tsx debug/stress-job-stream.ts",
    "listen": "npm run build && npx -y dotenv-cli -e .env -- node dist/worker.cjs"
  },
  "license": "ISC",
  "dependencies": {
    "@better-bull-board/client": "*",
    "@better-bull-board/db": "*",
    "@rharkor/logger": "^1.3.3",
    "@t3-oss/env-core": "^0.13.11",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "zod": "^4.3.6",
    "bullmq": "^5.76.0"
  },
  "exports": {
    "./*": {
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs"
    }
  },
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0"
  }
}
