#* Environment
ENV=development
LOGGER_ENV=development
WEBSOCKET_URL=ws://localhost:8081
WEBSOCKET_PORT=8081

#* Ingest configuration
# 15 days in ms
AUTO_DELETE_POSTGRES_DATA=1296000000

#* Redis
REDIS_HOST=localhost
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_USE_TLS=false
REDIS_MAX_RETRIES_PER_REQUEST=null

#* Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
DATABASE_URL_NON_POOLING=postgresql://postgres:postgres@localhost:5432/postgres

#* Clickhouse
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=password
CLICKHOUSE_DB=default

#* Authentication
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=secret
JWT_SECRET=secret

#* MCP Server
# Generate with: openssl rand -base64 48
BBB_MCP_TOKEN=replace-with-at-least-32-characters
BBB_MCP_HOST=127.0.0.1
BBB_MCP_PORT=3333
