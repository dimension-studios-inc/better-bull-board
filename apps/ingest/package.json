{
  "name": "@better-bull-board/ingest",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "npx -y dotenv-cli -e .env -- tsx watch src/index.ts",
    "type-check": "tsc --noEmit",
    "debug": "npx -y dotenv-cli -e .env -- tsx debug/index.ts"
  },
  "license": "ISC",
  "dependencies": {
    "@better-bull-board/db": "*",
    "@better-bull-board/typescript-config": "*",
    "@rharkor/logger": "^1.3.3",
    "@t3-oss/env-core": "^0.13.11",
    "bullmq": "^5.76.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "ioredis": "^5.10.1",
    "redlock": "^5.0.0-beta.2",
    "tsdown": "^0.21.9",
    "typescript": "^6.0.3",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "drizzle-orm": "*",
    "pg": "*"
  },
  "exports": {
    "./*": {
      "types": "./dist/*.d.mts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs"
    }
  },
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.21.0"
  }
}
